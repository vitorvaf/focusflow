# =============================================================================
# FocusFlow — .gitignore
# Stack: .NET 8, Electron, React, TypeScript, Vite, SQLite, Node.js
# =============================================================================

# =============================================================================
# .NET / C#
# =============================================================================
## Build outputs
bin/
obj/
out/

## Publish output
src/FocusFlow.Api/bin/publish/

## NuGet
*.nupkg
*.snupkg
.nuget/
packages/
project.lock.json
project.fragment.lock.json
artifacts/

## Visual Studio / Rider
.vs/
.idea/
*.user
*.suo
*.userprefs
*.sln.docstates
*.pidb
*.ncb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb

## MSBuild
*.log
msbuild.log

## Test results
TestResults/
*.trx
*.coverage
*.coveragexml
coverage/
coverage-report/

## Entity Framework
# Keep migrations, ignore generated snapshots is not recommended — keep both
# Uncomment below only if you're sure:
# Migrations/

## Secrets / local config
appsettings.Local.json
appsettings.*.Local.json
secrets.json

## SQLite databases (runtime data — not source)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# =============================================================================
# Node.js / npm
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/
.yarn/
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

## Lock files — commit the one your project uses, ignore the others
# If using npm (package-lock.json), ignore:
yarn.lock
pnpm-lock.yaml
# If using yarn, ignore package-lock.json instead

## Runtime / cache
.cache/
.parcel-cache/
.turbo/

# =============================================================================
# Vite
# =============================================================================
dist/
dist-renderer/
dist-electron/
.vite/
vite.config.*.timestamp-*

# =============================================================================
# Electron / electron-builder
# =============================================================================
## Packaged app outputs
release/
dist/installers/
dist/win-unpacked/
dist/linux-unpacked/
dist/mac/
dist/*.exe
dist/*.msi
dist/*.dmg
dist/*.AppImage
dist/*.deb
dist/*.rpm
dist/*.snap
*.blockmap

## Electron builder cache
.electron-builder-cache/

